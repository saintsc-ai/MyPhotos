# Runtime data (carry separately when porting)
data/
*.db
*.db-wal
*.db-shm

# Local configuration (per-environment)
config/local.toml

# Docker Compose environment (per-host paths, UID/GID)
.env

# Vendor binaries (download per OS at bootstrap time)
vendor/linux-x64/*
vendor/linux-arm64/*
vendor/windows-x64/*
vendor/macos-arm64/*
!vendor/**/.gitkeep
!vendor/README.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# IDE / OS / agent
.claude/
.vscode/
.idea/

# Frontend libraries used to be gitignored + downloaded by
# scripts/download-frontend-libs.sh per host, but that left every
# fresh clone (Synology / Linux / Windows / Docker) with broken
# admin donut charts unless the user knew to run the script. Now
# Chart.js + datalabels are committed (~220 KB total, minified).
# Run scripts/download-frontend-libs.sh --force to refresh on a
# version bump — pins live in that script.
*.swp
.DS_Store
Thumbs.db
desktop.ini

# Claude Code / agent context — personal notes (host details, habits,
# debugging shortcuts) live here. Keep them local rather than in the
# public repo.
CLAUDE.md
