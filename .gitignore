# Runtime data (carry separately when porting)
data/
*.db
*.db-wal
*.db-shm

# Local configuration (per-environment)
config/local.toml

# Docker Compose environment (per-host paths, UID/GID)
.env

# Vendor binaries (download per OS at bootstrap time)
vendor/linux-x64/*
vendor/linux-arm64/*
vendor/windows-x64/*
vendor/macos-arm64/*
!vendor/**/.gitkeep
!vendor/README.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# IDE / OS / agent
.claude/
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# Claude Code / agent context — personal notes (host details, habits,
# debugging shortcuts) live here. Keep them local rather than in the
# public repo.
CLAUDE.md
