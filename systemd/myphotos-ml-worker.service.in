[Unit]
Description=MyPhotos ML Worker (YOLO / CLIP / faces)
After=network-online.target myphotos-api.service myphotos-worker.service
Wants=network-online.target

[Service]
Type=simple
User=@APP_USER@
Group=@APP_GROUP@
WorkingDirectory=@APP_DIR@
Environment=PYTHONUTF8=1
# onnxruntime ships AVX2 kernels but also threads its own scheduler;
# leave OMP_NUM_THREADS unset so it picks a sensible default for the host.
# Pre-flight: import the OCR stack so a broken env (missing rapidocr /
# cv2 libGL etc.) fails LOUDLY at systemctl start instead of silently
# disabling OCR in-process — which is how the user lost ~3 days of
# OCR work without noticing.
ExecStartPre=@APP_DIR@/.venv/bin/python -c "import cv2; from rapidocr import RapidOCR"
ExecStart=@APP_DIR@/.venv/bin/python -m app.worker_ml.main
Restart=on-failure
RestartSec=10
# ML inference is CPU-heavy — yield even more aggressively than the
# indexing worker so the API stays snappy.
Nice=15
IOSchedulingClass=best-effort
IOSchedulingPriority=7
# Logs: journalctl -u myphotos-ml-worker -f

[Install]
WantedBy=multi-user.target
