[Unit]
Description=MyPhotos Worker (scanner + jobs)
After=network-online.target myphotos-api.service
Wants=network-online.target

[Service]
Type=simple
User=@APP_USER@
Group=@APP_GROUP@
WorkingDirectory=@APP_DIR@
Environment=PYTHONUTF8=1
ExecStart=@APP_DIR@/.venv/bin/python -m app.worker.main
Restart=on-failure
RestartSec=10
# Be a polite neighbour to other NAS services
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=5
# Logs go to the systemd journal: journalctl -u myphotos-worker -f
# (MemoryMax / StandardOutput=append: removed — DSM systemd is too old)

[Install]
WantedBy=multi-user.target
