# MyPhotos — Docker Compose environment.
# Copy to `.env` (gitignored) and adjust per host.
#
#   cp .env.example .env
#   docker compose up -d

# Host path to your photo library. Mounted read-only at /photos in the
# containers — the scanner only ever reads from it.
#   DSM example:     /volume1/photo
#   Windows dev:     D:/Photos          (forward slashes work in compose)
#   Linux dev:       /home/me/Pictures
PHOTO_ROOT=/volume1/photo

# Host directory for runtime state (catalog DB, thumbnails, logs, trash, ML
# models). Create it before `compose up` AND chown it to the container user
# (UID 1000 for the prebuilt GHCR image): `sudo chown -R 1000:1000 <path>`.
# The container runs non-root and writes here, so a root-owned dir makes the
# api container die on boot (see the Docker guide, step 1).
# Keep it on the same fast disk as the DB for best random-read performance.
DATA_DIR=./data

# Host directory holding default.toml + local.toml. Containers read both;
# the admin UI writes back to local.toml. Leave as ./config to use what's
# in the repo — but it must be readable+writable by the container user
# (UID 1000), or alembic dies reading default.toml on boot and the api
# crash-loops: `sudo chown -R 1000:1000 config`. See the Docker guide, step 1.
CONFIG_DIR=./config

# Host port for the web UI / API. Pick anything free; container always
# listens on 8888 internally.
API_PORT=8888

# Display timezone. EXIF/file times are stored as UTC and rendered in this
# zone by the UI.
TZ=Asia/Seoul

# Override the image. Default is GHCR's published `:latest`. Use a local
# tag (e.g. myphotos:dev) when you want to build from your working tree
# instead of pulling.
#   IMAGE=myphotos:dev

# UID/GID the container processes run as. NOTE: these are *build-time* args —
# they only take effect when you build the image locally (IMAGE=myphotos:dev
# + `docker compose up -d --build`). The prebuilt GHCR image is fixed at
# 1000:1000, so if you pull it (the default), leave these as-is and instead:
#   - chown DATA_DIR to 1000  (so /app/data is writable), and
#   - give UID 1000 read access to your photo folder (chmod / ACL).
# Change them only when building your own image to run as the account that
# owns your photo files:
#   Linux/NAS: run `id -u` and `id -g` as the photo-owning account.
#   Windows: leave the defaults; Docker Desktop handles ownership.
APP_UID=1000
APP_GID=1000
